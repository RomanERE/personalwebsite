PORT=3000

# Gmail акаунт для відправки (той самий що і на PHP сервері)
MAIL_USER=your_gmail@gmail.com

# Gmail App Password (не звичайний пароль!)
# Google Account → Security → 2-Step Verification → App passwords
MAIL_PASS=xxxx_xxxx_xxxx_xxxx

# From-адреса (може бути domain або той самий gmail)
MAIL_FROM=your_gmail@gmail.com
